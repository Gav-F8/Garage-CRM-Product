# Copy this file to .env.local and fill in the values from
# Firebase console → Project settings → General → Your apps → SDK setup.
# .env.local is gitignored (*.local) — never commit real values.
#
# Note: the Firebase web API key is a project identifier, not a secret —
# it ships in the client bundle. Access control comes from Firestore rules,
# Auth custom claims, and App Check (see FIREBASE.md).

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# App Check: Firebase console → App Check → your web app → reCAPTCHA v3 site key.
# Optional — App Check is skipped if unset.
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
